{
    "version": 2,
    "crons": [
        {
            "path": "/api/attachments/cleanup-expired",
            "schedule": "0 3 * * *"
        }
    ],
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        },
        {
            "src": "server/server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server/server.js"
        },
        {
            "src": "/fonts/(.*)",
            "dest": "server/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/client/$1",
            "check": true
        },
        {
            "src": "/(.*)",
            "status": 200,
            "dest": "client/index.html"
        }
    ]
}
